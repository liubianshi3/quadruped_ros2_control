<?xml version="1.0"?>
<!--
  Dog2 Robot Description (Xacro Source)

  Prismatic (slider) link inertial COM offsets are l1_inertia_xyz … l4_inertia_xyz
  (properties below). First component: legs 1 and 3 use −X, legs 2 and 4 use +X;
  Y and Z match across all four. If you change those properties, update this note
  so it stays accurate—do not infer signs from front/rear leg grouping alone.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="dog2">

  <xacro:arg name="controllers_yaml" default="$(find dog2_description)/config/ros2_controllers.yaml"/>
  <xacro:property name="controllers_yaml" value="$(arg controllers_yaml)"/>

  <!--
    Joint limits (authoritative for RViz, IK, runtime clamping).
    femur_joint and tibia_joint are distinct pitch DOFs: each has its own lower/upper/effort/velocity.
  -->
  <xacro:property name="coxa_lower_limit" value="-2.618"/>
  <xacro:property name="coxa_upper_limit" value="2.618"/>
  <xacro:property name="coxa_effort" value="50"/>
  <xacro:property name="coxa_velocity" value="20"/>
  <xacro:property name="femur_lower_limit" value="-2.8"/>
  <xacro:property name="femur_upper_limit" value="2.8"/>
  <xacro:property name="femur_effort" value="50"/>
  <xacro:property name="femur_velocity" value="20"/>
  <xacro:property name="tibia_lower_limit" value="-2.8"/>
  <xacro:property name="tibia_upper_limit" value="2.8"/>
  <xacro:property name="tibia_effort" value="50"/>
  <xacro:property name="tibia_velocity" value="20"/>
  <xacro:property name="prismatic_effort" value="100"/>
  <xacro:property name="prismatic_velocity" value="5"/>

  <!-- Shared angle constants -->
  <xacro:property name="PI_CONST" value="3.141592653589793"/>
  <xacro:property name="half_pi" value="1.5707963267948966"/>

  <!-- 左右腿镜像：rail / 右侧髋关节 / 右侧膝几何 由常量表达，单腿仅保留必要不对称（如 hip_xyz、大腿 mesh 翻转）。 -->
  <xacro:property name="leg_rail_rpy_L" value="${half_pi} 0 0"/>
  <xacro:property name="leg_rail_rpy_R" value="${half_pi} 0 ${-PI_CONST}"/>
  <!-- Local rail axis: chosen so R_rail * axis = base_link +X for +q slide (left vs right mirror). -->
  <xacro:property name="leg_rail_axis_L" value="1 0 0"/>
  <xacro:property name="leg_rail_axis_R" value="-1 0 0"/>
  <!-- Right coxa joint rpy used on rh; kept for docs / tooling. -->
  <xacro:property name="leg_hip_rpy_R" value="${PI_CONST} 0 ${half_pi}"/>
  <xacro:property name="leg_knee_xyz_R" value="-0.0233 -0.055 -0.0254"/>
  <xacro:property name="leg_thigh_mesh_flip_rpy" value="0 ${PI_CONST} 0"/>
  <!--
    Phase 2 — classify before moving (do not flatten blindly)
    ===========================================================
    Phase 2 mount absorption (hip_rpy_R → mount L + rail L + hip_xyz closure) rolled back
    on rh and rf: translation-only closure broke coxa_link full SE(3). Both legs again use
    leg_rail_rpy_R + leg_rail_axis_R + leg_hip_rpy_R + leg_knee_xyz_R; rf keeps explicit
    hip_xyz 0.0116 0.0199 0.055 (pre-Phase 2). Next: axis_frame explicit joints; any redo
    must SE(3)-match coxa/femur/tibia/foot, not position-only.

    (a′) leg_knee_xyz_R — still on rh/rf femur_joint (B).

    Re-run dog2_description/scripts/check_joint_semantics.py and kinematics tests
    after any relocation of these parameters.
  -->

  <!-- Joint passive dynamics (simulation stabilization) -->
  <xacro:property name="prismatic_damping" value="0.25"/>
  <xacro:property name="prismatic_friction" value="0.05"/>
  <xacro:property name="hip_damping" value="0.12"/>
  <xacro:property name="hip_friction" value="0.02"/>
  <xacro:property name="femur_damping" value="0.15"/>
  <xacro:property name="femur_friction" value="0.02"/>
  <xacro:property name="tibia_damping" value="0.15"/>
  <xacro:property name="tibia_friction" value="0.02"/>

  <!-- Contact model (conservative baseline for stability) -->
  <xacro:property name="foot_contact_mu1" value="1.0"/>
  <xacro:property name="foot_contact_mu2" value="1.0"/>
  <xacro:property name="foot_contact_kp" value="2.0e4"/>
  <xacro:property name="foot_contact_kd" value="20.0"/>
  <xacro:property name="foot_contact_min_depth" value="0.0005"/>
  <xacro:property name="foot_contact_max_vel" value="0.2"/>

  <!-- Inertia properties -->
  <xacro:property name="leg12_thigh_xyz" value="0.026 -0.0760041259902766 0.0649874821212071"/>
  <xacro:property name="leg12_shin_xyz" value="0.0254901816398352 -0.143524743603395 -0.0694046953395906"/>
  <xacro:property name="leg3_thigh_xyz" value="-0.0259999999999999 -0.0760041259902766 0.0649874821212069"/>
  <xacro:property name="leg3_shin_xyz" value="-0.0265098183601649 -0.143524743603395 -0.0694046953395908"/>
  <xacro:property name="leg4_thigh_xyz" value="-0.026 -0.0760041259902766 0.0649874821212069"/>
  <xacro:property name="leg4_shin_xyz" value="-0.0265089672547710 -0.1429895138560395 -0.0691152554666486"/>

  <!--
    *_foot_tip_xyz (tibia_link): origin of *_foot_fixed — analytical foot sphere center
    (foot_link visual / collision / inertial). X: foot_tip_lateral_inboard_m with per-leg sign;
    Y/Z: built from foot_sphere_radius helpers plus literals in leg12_*, leg3_*, leg4_* below.
  -->
  <xacro:property name="foot_sphere_radius" value="0.012"/>
  <xacro:property name="foot_tip_plus_y_half_diameter_m" value="${foot_sphere_radius}"/>
  <xacro:property name="foot_tip_minus_y_one_and_half_diameter_m" value="${3 * foot_sphere_radius}"/>
  <xacro:property name="foot_tip_lateral_inboard_m" value="0.024"/>
  <xacro:property name="foot_tip_z_down_m" value="0.012"/>
  <xacro:property name="leg12_foot_tip_xyz" value="${foot_tip_lateral_inboard_m} ${foot_tip_plus_y_half_diameter_m - foot_tip_minus_y_one_and_half_diameter_m - 0.269179} -0.142168"/>
  <xacro:property name="leg3_foot_tip_xyz" value="-${foot_tip_lateral_inboard_m} ${foot_tip_plus_y_half_diameter_m - foot_tip_minus_y_one_and_half_diameter_m - 0.269179} -0.142168"/>
  <xacro:property name="leg4_foot_tip_xyz" value="-${foot_tip_lateral_inboard_m} ${foot_tip_plus_y_half_diameter_m - foot_tip_minus_y_one_and_half_diameter_m - 0.269202} -0.142121"/>

  <!--
    Semantic base root (current source-of-truth)
    ============================================================
    Historical urdf_shift_* bookkeeping and the fake URDF-level
    `base_footprint` root have both been removed. `base_link` is now the only
    URDF root for control / dynamics / leg installation.

    STRICT BOUNDARY:
      * DO NOT re-introduce urdf_shift_* or a second hidden compensation layer
        in TF publishers, sensor extrinsics, MPC/WBC kinematics, Python config,
        or controller code.
      * DO NOT re-introduce a fake `base_footprint` or another fixed root
        wrapper inside the URDF just to preserve historical naming.

    MAINTENANCE RULE:
      If a planning/ground-projection frame is needed in the future, publish a
      runtime `base_footprint` TF outside the URDF. Keep the xacro rooted at
      semantic `base_link` and re-baseline the guardrails and stand-geometry
      golden only when the semantic base definition itself changes.
  -->
  <!--
    Semantic trunk root definition
    ============================================================
    base_link is intentionally redefined as the control / dynamics / leg-install
    root near the geometric center of the four leg mounts. It is not required to
    coincide with the CAD shell origin.

    The trunk mesh still uses a baked visual offset, so the visual origin is
    expressed directly on base_link while leg mounts, trunk inertial, and trunk
    collision remain in this semantic base_link frame.
  -->
  <xacro:property name="base_link_semantic_origin_x" value="0.248975"/>
  <xacro:property name="base_link_semantic_origin_y" value="0.122500"/>
  <xacro:property name="base_link_semantic_origin_z" value="0.0"/>
  <!-- Conservative trunk collision box derived from the legacy collision mesh bbox.
       The upper ~1/3 is trimmed away while keeping the lower envelope unchanged. -->
  <xacro:property name="trunk_collision_box_xyz"
                  value="${0.243115 - base_link_semantic_origin_x} ${0.122499 - base_link_semantic_origin_y} ${-0.006837 - base_link_semantic_origin_z}"/>
  <xacro:property name="trunk_collision_box_size" value="0.342 0.160 0.100333"/>

  <!--
    Current trunk ownership:
      base_link = URDF / ROS / control / Pinocchio root frame
                  (X front, Y left, Z up), carrying trunk inertial + collision
                  + visual, plus all four leg mounts.
    base_link is defined around the leg-mount centroid. The trunk mesh still
    keeps its historical baked visual offset, expressed directly below.
  -->
  <link name="base_link">
    <!--
      Trunk inertial mapping (FROZEN unless re-baselined on purpose)
      ================================================================
      The inertial <origin rpy="half_pi 0 0"/> (+90 deg about +X, property half_pi)
      is intentional: it maps exported rigid-body inertia from the CAD solid frame
      into base_link as a REP-103 body (X forward, Y left, Z up). After this
      rotation, the diagonal entries align with plausible trunk semantics in
      base_link (lightest about body longitudinal X, heaviest about body-vertical Z).

      The small ixy coupling is expected: CAD-export tensor plus frame rotation,
      not principal axes already diagonal in base_link.

      Do not remove this rpy, do not set it to 0 0 0, and do not tweak this block
      for cosmetic reasons. Revisit only with explicit new evidence (e.g. inertia
      re-exported already in the ROS base_link convention, CAD axis convention
      change, or a written report that this rotation is no longer required).
    -->
    <inertial>
      <origin xyz="${0.2492 - base_link_semantic_origin_x} ${0.12503 - base_link_semantic_origin_y} ${0.0 - base_link_semantic_origin_z}" rpy="${half_pi} 0 0"/>
      <mass value="6.0"/>
      <inertia ixx="0.0153" ixy="0.00011" ixz="0" iyy="0.052" iyz="0" izz="0.044"/>
    </inertial>
    <collision>
      <origin xyz="${trunk_collision_box_xyz}" rpy="0 0 0"/>
      <geometry>
        <box size="${trunk_collision_box_size}"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="${0.0 - base_link_semantic_origin_x - 0.9780} ${0.0 - base_link_semantic_origin_y + 0.87203} -0.2649" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/base_link.STL"/>
      </geometry>
      <material name="mat_base_gray">
        <color rgba="0.752941176470588 0.752941176470588 0.752941176470588 1"/>
      </material>
    </visual>
  </link>

  <xacro:property name="l1_inertia_xyz" value="-0.0159999123716776 0.000737036465389251 0.0261570925915838"/>
  <xacro:property name="l2_inertia_xyz" value="0.0159999123716776 0.000737036465389251 0.0261570925915838"/>
  <xacro:property name="l3_inertia_xyz" value="-0.0159999123716776 0.000737036465389251 0.0261570925915838"/>
  <xacro:property name="l4_inertia_xyz" value="0.0159999123716776 0.000737036465389251 0.0261570925915838"/>

  <!--
    ========================================================================
    Leg kinematic contract (single source of truth for topology semantics)
    ========================================================================

    Family: **1P + 3R** redundant leg — prismatic rail on the body plus a
    classic **Yaw–Pitch–Pitch** (spider / insect–like) chain in 3D.

    Kinematic shorthand: **P – R_z – R_y – R_y** (mixed / redundant leg). The
    R_z / R_y labels name rotation *families* (yaw vs pitch); the signed list
    below is the effective instantaneous axis in **base_link** at q = 0 (nominal
    pose), not “per-leg flip” shorthand.

    **base_link** (REP-103: X forward, Y left, Z up). Validated by
    dog2_description/scripts/check_joint_semantics.py:

    rail_joint:  **+X** (prismatic; local rail axis is mirrored per leg so
                 composed motion is always body +X for +q).
    coxa_joint:  semantic hip yaw about **−Z** (all four legs at nominal pose).
    femur_joint: semantic thigh pitch about **−Y**.
    tibia_joint: semantic knee pitch about **−Y** (parallel to femur at q = 0).

    URDF <axis> vectors are in each joint’s URDF joint frame (child at q = 0);
    they are **not** raw base_link tuples. Use the signed semantics above in
    control / IK discussion; controllers, Pinocchio, and
    dog2_motion_control/dog2_motion_control/joint_semantics.py must stay
    consistent with it.

    **Do not** reintroduce a second global CAD/root compensation layer; see
    the semantic base placement comment above.

    ========================================================================
  -->
  <!-- Leg macro -->
  <xacro:macro name="leg" params="prefix leg_num parent_link rail_axis p_low p_up thigh_xyz shin_xyz slider_inertia_xyz foot_tip_xyz
                                 hip_rpy:='0 0 ${half_pi}' hip_xyz:='-0.016 0.0199 0.055'
                                 knee_xyz:='-0.0233 -0.055 0.0274'">

  <link name="${prefix}_rail_link">
    <inertial>
      <origin rpy="0 0 0" xyz="${slider_inertia_xyz}"/>
      <mass value="0.3"/>
      <inertia ixx="0.0001071" ixy="0" ixz="0" iyy="8.386e-05" iyz="0" izz="7.869e-05"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l${leg_num}.STL"/>
      </geometry>
      <material name="mat_white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://dog2_description/meshes/collision/l${leg_num}_collision.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="${prefix}_rail_joint" type="prismatic">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="${parent_link}"/>
    <child link="${prefix}_rail_link"/>
    <!-- +q translates along base_link +X (see kinematic contract block above). -->
    <axis xyz="${rail_axis}"/>
    <limit effort="${prismatic_effort}" lower="${p_low}" upper="${p_up}" velocity="${prismatic_velocity}"/>
    <dynamics damping="${prismatic_damping}" friction="${prismatic_friction}"/>
  </joint>

  <xacro:property name="coxa_parent_link" value="${prefix}_rail_link"/>
  <xacro:property name="coxa_child_link" value="${prefix}_coxa_link"/>
  <xacro:property name="coxa_joint_xyz_eff" value="${hip_xyz}"/>
  <xacro:property name="coxa_joint_rpy_eff" value="${hip_rpy}"/>
  <xacro:property name="coxa_axis_eff" value="-1 0 0"/>
  <xacro:if value="${prefix == 'lf' or prefix == 'lh'}">
    <link name="${prefix}_coxa_axis_frame"/>
    <link name="${prefix}_coxa_drive_frame"/>
    <joint name="${prefix}_coxa_axis_fixed" type="fixed">
      <parent link="${prefix}_rail_link"/>
      <child link="${prefix}_coxa_axis_frame"/>
      <origin xyz="${hip_xyz}" rpy="${-half_pi} 0 0"/>
    </joint>
    <xacro:property name="coxa_parent_link" value="${prefix}_coxa_axis_frame"/>
    <xacro:property name="coxa_child_link" value="${prefix}_coxa_drive_frame"/>
    <xacro:property name="coxa_joint_xyz_eff" value="0 0 0"/>
    <xacro:property name="coxa_joint_rpy_eff" value="0 0 0"/>
    <xacro:property name="coxa_axis_eff" value="0 0 -1"/>
  </xacro:if>
  <xacro:if value="${prefix == 'rh'}">
    <link name="${prefix}_coxa_axis_frame"/>
    <link name="${prefix}_coxa_drive_frame"/>
    <joint name="${prefix}_coxa_axis_fixed" type="fixed">
      <parent link="${prefix}_rail_link"/>
      <child link="${prefix}_coxa_axis_frame"/>
      <origin xyz="${hip_xyz}" rpy="0 ${-half_pi} ${-half_pi}"/>
    </joint>
    <xacro:property name="coxa_parent_link" value="${prefix}_coxa_axis_frame"/>
    <xacro:property name="coxa_child_link" value="${prefix}_coxa_drive_frame"/>
    <xacro:property name="coxa_joint_xyz_eff" value="0 0 0"/>
    <xacro:property name="coxa_joint_rpy_eff" value="0 0 0"/>
    <xacro:property name="coxa_axis_eff" value="0 0 -1"/>
  </xacro:if>

  <link name="${prefix}_coxa_link">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.0233 -0.0383 0.000879"/>
      <mass value="0.25"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l${leg_num}1.STL"/>
      </geometry>
      <material name="mat_blue"><color rgba="0.266 0.529 1 1"/></material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://dog2_description/meshes/collision/l${leg_num}1_collision.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="${prefix}_coxa_joint" type="revolute">
    <origin rpy="${coxa_joint_rpy_eff}" xyz="${coxa_joint_xyz_eff}"/>
    <parent link="${coxa_parent_link}"/>
    <child link="${coxa_child_link}"/>
    <axis xyz="${coxa_axis_eff}"/>
    <limit effort="${coxa_effort}" lower="${coxa_lower_limit}" upper="${coxa_upper_limit}" velocity="${coxa_velocity}"/>
    <dynamics damping="${hip_damping}" friction="${hip_friction}"/>
  </joint>
  <xacro:if value="${prefix == 'lf' or prefix == 'lh'}">
    <joint name="${prefix}_coxa_pose_fixed" type="fixed">
      <parent link="${prefix}_coxa_drive_frame"/>
      <child link="${prefix}_coxa_link"/>
      <origin xyz="0 0 0" rpy="0 ${-half_pi} ${half_pi}"/>
    </joint>
  </xacro:if>
  <xacro:if value="${prefix == 'rh'}">
    <joint name="${prefix}_coxa_pose_fixed" type="fixed">
      <parent link="${prefix}_coxa_drive_frame"/>
      <child link="${prefix}_coxa_link"/>
      <origin xyz="0 0 0" rpy="0 ${-half_pi} 0"/>
    </joint>
  </xacro:if>

  <link name="${prefix}_femur_link">
    <inertial>
      <origin rpy="0 0 0" xyz="${thigh_xyz}"/>
      <mass value="0.4"/>
      <inertia ixx="0.000666" ixy="0" ixz="0" iyy="0.000356" iyz="0.000266" izz="0.000534"/>
    </inertial>
    <!-- Femur mesh/collision-only rpy (not joint semantics). rf: CAD mesh flip via leg_thigh_mesh_flip_rpy. -->
    <xacro:property name="thigh_vis_rpy" value="0 0 0"/>
    <xacro:property name="thigh_col_rpy_eff" value="0 0 0"/>
    <xacro:if value="${prefix == 'rf'}">
      <xacro:property name="thigh_vis_rpy" value="${leg_thigh_mesh_flip_rpy}"/>
      <xacro:property name="thigh_col_rpy_eff" value="${leg_thigh_mesh_flip_rpy}"/>
    </xacro:if>
    <visual>
      <origin rpy="${thigh_vis_rpy}" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l${leg_num}11.STL"/>
      </geometry>
      <material name="mat_white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision>
      <origin rpy="${thigh_col_rpy_eff}" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://dog2_description/meshes/collision/l${leg_num}11_collision.STL"/>
      </geometry>
    </collision>
  </link>

  <xacro:property name="femur_parent_link" value="${prefix}_coxa_link"/>
  <xacro:property name="femur_child_link" value="${prefix}_femur_link"/>
  <xacro:property name="femur_joint_xyz_eff" value="${knee_xyz}"/>
  <xacro:property name="femur_joint_rpy_eff" value="${half_pi} ${half_pi} 0"/>
  <xacro:property name="femur_axis_eff" value="-1 0 0"/>
  <xacro:if value="${prefix == 'lf' or prefix == 'lh' or prefix == 'rh' or prefix == 'rf'}">
    <link name="${prefix}_femur_axis_frame"/>
    <link name="${prefix}_femur_drive_frame"/>
    <joint name="${prefix}_femur_axis_fixed" type="fixed">
      <parent link="${prefix}_coxa_link"/>
      <child link="${prefix}_femur_axis_frame"/>
      <origin xyz="${knee_xyz}" rpy="${-half_pi} 0 0"/>
    </joint>
    <xacro:property name="femur_parent_link" value="${prefix}_femur_axis_frame"/>
    <xacro:property name="femur_child_link" value="${prefix}_femur_drive_frame"/>
    <xacro:property name="femur_joint_xyz_eff" value="0 0 0"/>
    <xacro:property name="femur_joint_rpy_eff" value="0 0 0"/>
    <xacro:property name="femur_axis_eff" value="0 -1 0"/>
  </xacro:if>

  <joint name="${prefix}_femur_joint" type="revolute">
    <origin rpy="${femur_joint_rpy_eff}" xyz="${femur_joint_xyz_eff}"/>
    <parent link="${femur_parent_link}"/>
    <child link="${femur_child_link}"/>
    <axis xyz="${femur_axis_eff}"/>
    <limit effort="${femur_effort}" lower="${femur_lower_limit}" upper="${femur_upper_limit}" velocity="${femur_velocity}"/>
    <dynamics damping="${femur_damping}" friction="${femur_friction}"/>
  </joint>
  <xacro:if value="${prefix == 'lf' or prefix == 'lh' or prefix == 'rh' or prefix == 'rf'}">
    <joint name="${prefix}_femur_pose_fixed" type="fixed">
      <parent link="${prefix}_femur_drive_frame"/>
      <child link="${prefix}_femur_link"/>
      <origin xyz="0 0 0" rpy="0 ${PI_CONST} ${-half_pi}"/>
    </joint>
  </xacro:if>

  <link name="${prefix}_tibia_link">
    <inertial>
      <origin rpy="0 0 0" xyz="${shin_xyz}"/>
      <mass value="0.5"/>
      <inertia ixx="0.004517" ixy="0.0000087" ixz="0.0000042" iyy="0.000975" iyz="-0.001769" izz="0.003666"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://dog2_description/meshes/l${leg_num}111.STL"/>
      </geometry>
      <material name="mat_white"><color rgba="1 1 1 1"/></material>
    </visual>
    <!-- Collision is mesh STL (not a box/cylinder primitive). -->
    <collision>
      <geometry>
        <mesh filename="package://dog2_description/meshes/collision/l${leg_num}111_collision.STL"/>
      </geometry>
    </collision>
  </link>

  <xacro:property name="tibia_parent_link" value="${prefix}_femur_link"/>
  <xacro:property name="tibia_child_link" value="${prefix}_tibia_link"/>
  <xacro:property name="tibia_joint_xyz_eff" value="0 -0.15201 0.12997"/>
  <xacro:property name="tibia_joint_rpy_eff" value="0 0 0"/>
  <xacro:property name="tibia_axis_eff" value="-1 0 0"/>
  <xacro:if value="${prefix == 'lf' or prefix == 'lh' or prefix == 'rh' or prefix == 'rf'}">
    <link name="${prefix}_tibia_axis_frame"/>
    <link name="${prefix}_tibia_drive_frame"/>
    <joint name="${prefix}_tibia_axis_fixed" type="fixed">
      <parent link="${prefix}_femur_link"/>
      <child link="${prefix}_tibia_axis_frame"/>
      <origin xyz="0 -0.15201 0.12997" rpy="0 0 ${-half_pi}"/>
    </joint>
    <xacro:property name="tibia_parent_link" value="${prefix}_tibia_axis_frame"/>
    <xacro:property name="tibia_child_link" value="${prefix}_tibia_drive_frame"/>
    <xacro:property name="tibia_joint_xyz_eff" value="0 0 0"/>
    <xacro:property name="tibia_axis_eff" value="0 -1 0"/>
  </xacro:if>

  <joint name="${prefix}_tibia_joint" type="revolute">
    <origin rpy="${tibia_joint_rpy_eff}" xyz="${tibia_joint_xyz_eff}"/>
    <parent link="${tibia_parent_link}"/>
    <child link="${tibia_child_link}"/>
    <axis xyz="${tibia_axis_eff}"/>
    <limit effort="${tibia_effort}" lower="${tibia_lower_limit}" upper="${tibia_upper_limit}" velocity="${tibia_velocity}"/>
    <dynamics damping="${tibia_damping}" friction="${tibia_friction}"/>
  </joint>
  <xacro:if value="${prefix == 'lf' or prefix == 'lh' or prefix == 'rh' or prefix == 'rf'}">
    <joint name="${prefix}_tibia_pose_fixed" type="fixed">
      <parent link="${prefix}_tibia_drive_frame"/>
      <child link="${prefix}_tibia_link"/>
      <origin xyz="0 0 0" rpy="0 0 ${half_pi}"/>
    </joint>
  </xacro:if>

  <joint name="${prefix}_foot_fixed" type="fixed">
    <origin rpy="0 0 0" xyz="${foot_tip_xyz}"/>
    <parent link="${prefix}_tibia_link"/>
    <child link="${prefix}_foot_link"/>
  </joint>

  <!-- foot_link: 足端 frame 原点 = 球心；collision 与 visual 同球（r=foot_sphere_radius）。 -->
  <link name="${prefix}_foot_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="2.88e-06" ixy="0" ixz="0" iyy="2.88e-06" iyz="0" izz="2.88e-06"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="${foot_sphere_radius}"/>
      </geometry>
      <material name="mat_foot_debug"><color rgba="0.2 0.85 0.35 1"/></material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="${foot_sphere_radius}"/>
      </geometry>
    </collision>
  </link>

  <!--
    tibia_link: URDF collision is mesh (see collision block above), not a primitive.
    If the shin mesh brushes terrain, keep Gazebo contact soft/low-friction so
    the foot_link sphere stays the primary support.
  -->
  <gazebo reference="${prefix}_tibia_link">
    <mu1>0.05</mu1>
    <mu2>0.05</mu2>
    <kp>800</kp>
    <kd>8</kd>
    <minDepth>${foot_contact_min_depth}</minDepth>
    <maxVel>${foot_contact_max_vel}</maxVel>
  </gazebo>

  <gazebo reference="${prefix}_foot_link">
    <mu1>${foot_contact_mu1}</mu1>
    <mu2>${foot_contact_mu2}</mu2>
    <kp>${foot_contact_kp}</kp>
    <kd>${foot_contact_kd}</kd>
    <minDepth>${foot_contact_min_depth}</minDepth>
    <maxVel>${foot_contact_max_vel}</maxVel>
    <material>Gazebo/Grey</material>
    <sensor name="${prefix}_foot_contact" type="contact">
      <always_on>true</always_on>
      <update_rate>200</update_rate>
      <contact/>
    </sensor>
  </gazebo>

  </xacro:macro>

  <!-- Leg instantiations -->
  <!--
    Layering target (refactor guideline; world geometry unchanged until re-baselined)
    =============================================================================
    (1) Mount: *only* *_leg_mount_fixed origin vs base_link — real chassis asymmetry
        allowed here with a mechanical note.
    (2) Semantic chain: rail→coxa→femur→tibia→foot — aim for one parameter set;
        avoid per-leg hip/knee/foot patch unless unavoidable.
    (3) Geometry: mesh/collision-only flips — belong on visual/collision <origin>
        or an extra geom fixed frame, not on actuated joint semantics.

    Current state: rh/rf both use leg_rail_rpy_R + leg_rail_axis_R + leg_hip_rpy_R +
    leg_knee_xyz_R (Phase 2 mount experiment rolled back on both). rf explicit hip_xyz
    0.0116 0.0199 0.055. lh hip_xyz override unchanged. rf femur mesh/collision flip stays
    macro-internal (Phase 1). See Phase 2 block after leg_knee_xyz_R.

    Leg topology (base_link-local mount frames):
      lf left front | lh left rear | rh right rear | rf right front
  -->
  <link name="lf_leg_mount"/>
  <joint name="lf_leg_mount_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="lf_leg_mount"/>
    <origin xyz="${0.1246 - base_link_semantic_origin_x} ${0.0625 - base_link_semantic_origin_y} ${0.0 - base_link_semantic_origin_z}" rpy="${leg_rail_rpy_L}"/>
  </joint>

  <link name="lh_leg_mount"/>
  <joint name="lh_leg_mount_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="lh_leg_mount"/>
    <origin xyz="${0.3711 - base_link_semantic_origin_x} ${0.0625 - base_link_semantic_origin_y} ${0.0 - base_link_semantic_origin_z}" rpy="${leg_rail_rpy_L}"/>
  </joint>

  <link name="rh_leg_mount"/>
  <joint name="rh_leg_mount_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="rh_leg_mount"/>
    <origin xyz="${0.3711 - base_link_semantic_origin_x} ${0.1825 - base_link_semantic_origin_y} ${0.0 - base_link_semantic_origin_z}" rpy="${leg_rail_rpy_R}"/>
  </joint>

  <link name="rf_leg_mount"/>
  <joint name="rf_leg_mount_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="rf_leg_mount"/>
    <origin xyz="${0.1291 - base_link_semantic_origin_x} ${0.1825 - base_link_semantic_origin_y} ${0.0 - base_link_semantic_origin_z}" rpy="${leg_rail_rpy_R}"/>
  </joint>

  <!-- Leg 1: Front Left (lf) via lf_leg_mount -->
  <xacro:leg prefix="lf" leg_num="1" parent_link="lf_leg_mount" rail_axis="${leg_rail_axis_L}" p_low="0.0" p_up="0.111"
             thigh_xyz="${leg12_thigh_xyz}" shin_xyz="${leg12_shin_xyz}" slider_inertia_xyz="${l1_inertia_xyz}"
             foot_tip_xyz="${leg12_foot_tip_xyz}"/>

  <!-- Leg 2: Rear Left (lh) via lh_leg_mount -->
  <xacro:leg prefix="lh" leg_num="2" parent_link="lh_leg_mount" rail_axis="${leg_rail_axis_L}" p_low="-0.111" p_up="0.0"
             thigh_xyz="${leg12_thigh_xyz}" shin_xyz="${leg12_shin_xyz}" slider_inertia_xyz="${l2_inertia_xyz}"
             hip_xyz="0.016 0.0199 0.055"
             foot_tip_xyz="${leg12_foot_tip_xyz}"/>

  <!-- Leg 3: Rear Right (rh) via rh_leg_mount — Phase 2 mount absorption rolled back (coxa full SE(3)). -->
  <xacro:leg prefix="rh" leg_num="3" parent_link="rh_leg_mount" rail_axis="${leg_rail_axis_R}" p_low="0.0" p_up="0.111"
             thigh_xyz="${leg3_thigh_xyz}" shin_xyz="${leg3_shin_xyz}" slider_inertia_xyz="${l3_inertia_xyz}"
             hip_rpy="${leg_hip_rpy_R}" knee_xyz="${leg_knee_xyz_R}"
             foot_tip_xyz="${leg3_foot_tip_xyz}"/>

  <!-- Leg 4: Front Right (rf): chain semantics restored pre-Phase 2; femur mesh flip remains Phase 1 (macro internal). -->
  <xacro:leg prefix="rf" leg_num="4" parent_link="rf_leg_mount" rail_axis="${leg_rail_axis_R}" p_low="-0.111" p_up="0.0"
             thigh_xyz="${leg4_thigh_xyz}" shin_xyz="${leg4_shin_xyz}" slider_inertia_xyz="${l4_inertia_xyz}"
             hip_rpy="${leg_hip_rpy_R}" hip_xyz="0.0116 0.0199 0.055" knee_xyz="${leg_knee_xyz_R}"
             foot_tip_xyz="${leg4_foot_tip_xyz}"/>

  <!-- ROS 2 Control -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="lf_rail_joint">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lf_coxa_joint">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lf_femur_joint">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lf_tibia_joint">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lh_rail_joint">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lh_coxa_joint">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lh_femur_joint">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="lh_tibia_joint">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rh_rail_joint">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rh_coxa_joint">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rh_femur_joint">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rh_tibia_joint">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rf_rail_joint">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rf_coxa_joint">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rf_femur_joint">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rf_tibia_joint">
      <command_interface name="position"/>
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>${controllers_yaml}</parameters>
      <robot_param>robot_description</robot_param>
      <robot_param_node>robot_state_publisher</robot_param_node>
    </plugin>
  </gazebo>

</robot>
